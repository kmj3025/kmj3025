#include<iostream>
using namespace std;

int main()
{
	int a, b, c;
	int m = 0;
	cin >> a >> b >> c;
	if (a == b && b == c)
	{
		m = 10000 + a * 1000;
	}
	else if (a == b || b == c)
	{
		m = 1000 + b*100;
	}
	else if (a == c)
	{
		m = 1000 + a*100;
	}
	else if (a!=b && a!=c && b!=c)
	{
		if (a > b && a > c)
		{
			m = a*100;
		}
		else if (b > a && b > c)
		{
			m = b*100;
		}
		else if (c > b && c > a)
		{
			m = c*100;
		}
	}
	cout << m;


	return 0;
	
}
