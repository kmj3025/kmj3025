#include<iostream>
using namespace std;

int main()
{
	int n;
	cin >> n; //줄 개수 입력
	for (int i = 0; i < n; i++)//i가 0 1 2 3 4
		
	{
		for (int k = 1; k < (n - i); k++)
		{
			cout << " ";
		}
		for (int j = 0; j <= i; j++)
		{
			cout << "*";
		}
		
			
		
		cout << endl;//줄바꿈 n번수행
	}



	return 0;

}
