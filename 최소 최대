#include<iostream>
using namespace std;

int arr[1000000];
int main()
{
	
	int n; //정수의 개수
	cin >> n;
	
	for (int i = 0; i < n; i++)
	{
		cin >> arr[i];
	}
	int min = arr[0];
	int max = arr[0];

	for (int i = 0; i < n; i++)
	{
		
		if (max < arr[i])
		{
			max = arr[i];

		}
		if (min > arr[i])
		{
			min = arr[i];
		}
	}
	cout << min << " " << max;



	return 0;
}
